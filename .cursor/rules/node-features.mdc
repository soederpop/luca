Here is an example shell for a new feature

```typescript
import { Feature, features, type FeatureOptions, type FeatureState } from '../feature.js'

/**
 * The FeatureState type dictates what feature.state.set(...) looks like, what feautre.state.current looks like, etc
 */
export interface FeatureNameState extends FeatureState {
	connected: boolean	
}

/**
 * The FeatureOptions dictates what arguments the feautre is created with 
 * 
 * container.feature('featureName', { host, port })
 */
export interface FeatureNameOptions extends FeatureOptions {
	host: string
	port: number
	username: string
	password?: string
	key?: string
}

/**
 * Provide a detailed description of what the feature is fore
 * 
 */
export class FeatureName extends Feature {
	// camel case
  static override shortcut = 'features.featureName' as const

	// METHODS:
	// Add comprehensive JSDOC
}

// We have to register this feature with the features registry
export default features.register('secureShell', FeatureName)
```