{
  "name": "@soederpop/luca",
  "website": "https://luca-js.soederpop.com",
  "version": "0.3.9",
  "description": "lightweight universal conversational architecture AKA Le Ultimate Component Architecture AKA Last Universal Common Ancestor, part AI part Human",
  "author": "jon soeder aka the people's champ <jon@soederpop.com>",
  "type": "module",
  "repository": "https://github.com/soederpop/luca",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "conversational",
    "architecture",
    "universal",
    "ai",
    "agentic",
    "coding assistant"
  ],
  "main": "./src/node.ts",
  "types": "./dist/node.d.ts",
  "browser": "./src/browser.ts",
  "exports": {
    ".": {
      "types": "./dist/node.d.ts",
      "default": "./src/node.ts"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./src/node.ts"
    },
    "./node/*": {
      "types": "./dist/node/*.d.ts",
      "default": "./src/node/*"
    },
    "./web": {
      "types": "./dist/browser.d.ts",
      "default": "./src/browser.ts"
    },
    "./web/*": {
      "types": "./dist/web/*.d.ts",
      "default": "./src/web/*"
    },
    "./agi": {
      "types": "./dist/agi/index.d.ts",
      "default": "./src/agi/index.ts"
    },
    "./agi/*": {
      "types": "./dist/agi/*.d.ts",
      "default": "./src/agi/*"
    },
    "./schemas": {
      "types": "./dist/schemas/base.d.ts",
      "default": "./src/schemas/base.ts"
    },
    "./schemas/*": {
      "types": "./dist/schemas/*.d.ts",
      "default": "./src/schemas/*"
    },
    "./container": {
      "types": "./dist/container.d.ts",
      "default": "./src/container.ts"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./src/client.ts"
    },
    "./clients/*": {
      "types": "./dist/clients/*.d.ts",
      "default": "./src/clients/*"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./src/server.ts"
    },
    "./servers/*": {
      "types": "./dist/servers/*.d.ts",
      "default": "./src/servers/*"
    },
    "./feature": {
      "types": "./dist/feature.d.ts",
      "default": "./src/feature.ts"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./src/react/index.ts"
    },
    "./introspection": {
      "types": "./dist/introspection/index.d.ts",
      "default": "./src/introspection/index.ts"
    }
  },
  "bin": {
    "luca": "./src/cli/cli.ts"
  },
  "scripts": {
    "serve": "bun build:web && luca serve --any-port",
    "console": "ts-node --esm scripts/console.ts",
    "lint": "eslint src/ --ext .js,.jsx,.ts,.tsx",
    "clean": "rm -rf dist build package",
    "build:web": "bun run scripts/build-web.ts",
    "build:introspection": "bun run src/cli/cli.ts introspect",
    "compile": "bun run build:introspection && bun run build:scaffolds && bun run build:bootstrap && bun run build:python-bridge && bash scripts/stamp-build.sh && bun build ./src/cli/cli.ts --compile --outfile dist/luca --external node-llama-cpp",
    "build:types": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:scaffolds": "bun run src/cli/cli.ts build-scaffolds",
    "build:bootstrap": "bun run src/cli/cli.ts build-bootstrap",
    "build:python-bridge": "bun run src/cli/cli.ts build-python-bridge",
    "test": "bun test test/*.test.ts",
    "update-all-docs": "bun run test && bun run build:introspection && bun run src/cli/cli.ts generate-api-docs && bun run build:scaffolds && bun run build:bootstrap && bun run build:python-bridge",
    "setup": "git update-index --skip-worktree src/introspection/generated.node.ts src/introspection/generated.web.ts src/introspection/generated.agi.ts src/scaffolds/generated.ts src/bootstrap/generated.ts src/python/generated.ts",
    "precommit": "bun run typecheck && bun run update-all-docs && git add docs/apis/ && bun compile",
    "test:integration": "bun test ./test-integration/"
  },
  "devDependencies": {
    "@types/cacache": "15.0.1",
    "@types/chalk": "2.2.4",
    "@types/child-process-promise": "2.2.6",
    "@types/chokidar": "2.1.7",
    "@types/cors": "2.8.19",
    "@types/detect-port": "1.3.5",
    "@types/dotenv": "8.2.3",
    "@types/express": "4.17.23",
    "@types/figlet": "1.7.0",
    "@types/glob": "8.1.0",
    "@types/inquirer": "9.0.8",
    "@types/jest": "27.5.2",
    "@types/js-yaml": "4.0.9",
    "@types/lodash-es": "4.17.12",
    "@types/micromatch": "4.0.9",
    "@types/minimist": "1.2.5",
    "@types/node": "18.19.111",
    "@types/node-uuid": "0.0.29",
    "@types/object-hash": "3.0.6",
    "@types/react": "18.3.23",
    "@types/uuid": "9.0.8",
    "@types/ws": "8.18.1",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "eslint": "8.57.1",
    "mkdist": "1.6.0",
    "prettier": "2.8.8",
    "ts-node": "11.0.0-beta.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.12.1",
    "@openai/codex": "0.99.0",
    "@resvg/resvg-js": "2.6.2",
    "@supabase/supabase-js": "2.95.3",
    "@types/marked": "6.0.0",
    "@types/marked-terminal": "6.1.1",
    "axios": "1.13.6",
    "cacache": "17.1.4",
    "chalk": "5.4.1",
    "child-process-promise": "2.2.1",
    "chokidar": "3.6.0",
    "cli-markdown": "3.5.0",
    "compromise": "14.14.5",
    "contentbase": "0.2.0",
    "cors": "2.8.5",
    "detect-port": "1.6.1",
    "dotenv": "17.2.4",
    "endent": "2.1.0",
    "excalidraw-to-svg": "3.1.0",
    "express": "4.21.2",
    "figlet": "1.11.0",
    "glob": "11.0.2",
    "googleapis": "171.4.0",
    "grammy": "1.40.0",
    "inflect": "0.5.0",
    "ink": "6.7.0",
    "inquirer": "9.3.7",
    "ioredis": "5.10.1",
    "isomorphic-vm": "0.0.1",
    "isomorphic-ws": "5.0.0",
    "js-tiktoken": "1.0.21",
    "js-yaml": "4.1.0",
    "lodash-es": "4.17.21",
    "marked": "15.0.12",
    "marked-terminal": "7.3.0",
    "mdast-util-to-markdown": "1.5.0",
    "mdast-util-to-string": "3.2.0",
    "micromatch": "4.0.8",
    "minimist": "1.2.8",
    "node-uuid": "1.4.8",
    "object-hash": "3.0.0",
    "openai": "5.1.1",
    "opener": "1.5.2",
    "react": "19.2.4",
    "react-devtools-core": "7.0.1",
    "react-dom": "19.2.4",
    "react-reconciler": "0.33.0",
    "remark-gfm": "3.0.1",
    "rimraf": "5.0.10",
    "typescript": "5.9.3",
    "unist-util-find-after": "4.0.1",
    "unist-util-find-all-after": "4.0.1",
    "unist-util-find-all-before": "4.0.1",
    "unist-util-find-before": "3.0.1",
    "unist-util-select": "4.0.3",
    "unist-util-visit": "4.1.2",
    "wink-eng-lite-web-model": "1.8.1",
    "wink-nlp": "2.4.0",
    "ws": "8.18.2",
    "zod": "4.3.6"
  },
  "optionalDependencies": {
    "node-llama-cpp": "3.17.1"
  },
  "overrides": {
    "@soederpop/luca": "."
  },
  "luca": {
    "aliases": [
      "luca",
      "framework",
      "container",
      "runtime"
    ]
  }
}
